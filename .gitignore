# Environment & secrets — NEVER commit
.env
.env.local
.env.production
.env.*.local

# User-specific config (only example.* is tracked)
config/network_profile.json
config/device_register.yaml
config/client_register.yaml
config/household_profile.yaml
config/dismissals.yaml
config/origin_stories.yaml
config/profile_history.yaml

# Operator-specific Claude Code project instructions — keeps personal
# network/household details out of the public repo. CLAUDE.md (the public
# tracked file) imports it via `@CLAUDE.local.md` when present.
CLAUDE.local.md

# Live-network captured fixtures — contain real MACs, IPs, hostnames.
# Forks should capture their own with `nye test --snapshot`.
tests/fixtures/baseline_snapshot.json
tests/fixtures/*.local.json

# Runtime data
logs/
snapshots/

