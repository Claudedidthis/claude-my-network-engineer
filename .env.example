# ClaudeMyNetworkEngineer — .env template
# Copy this file to `.env` and fill in real values.
# `.env` is in .gitignore and MUST never be committed.
# Claude Code is configured (.claude/settings.json) to refuse to read or write this file.

# ─────────────────────────────────────────────────────────────
# UniFi local API (Phase 1)
# ─────────────────────────────────────────────────────────────
UNIFI_HOST=192.168.1.1
UNIFI_PORT=443
UNIFI_SITE=default
UNIFI_API_KEY=
# Mode toggle for dev vs prod: live | fixtures
UNIFI_MODE=live

# ── SSL policy (directive 1.2) ───────────────────────────────────────
# UNIFI_SSL_MODE controls how the controller's certificate is verified.
# Default LAN_ONLY refuses construction if UNIFI_HOST is not RFC1918 /
# loopback / link-local — so a misconfigured public UNIFI_HOST fails
# fast rather than silently disabling cert verification.
#
#   lan_only   — verify=False, but only when host is a private IP literal.
#                Suitable for the default home-LAN deployment shape.
#   ca_bundle  — verify against the CA bundle at UNIFI_CA_BUNDLE (PEM).
#                Use when the operator has signed the UDM cert with a
#                custom CA and distributed the CA bundle.
#   pinned     — verify against UNIFI_CERT_FINGERPRINT (sha256 hex of leaf).
#                REQUIRED before exposing the controller via Cloudflare
#                Tunnel (Phase 14). Currently raises NotImplementedError;
#                the configuration is validated so operators can stage
#                the env without surprises.
UNIFI_SSL_MODE=lan_only
UNIFI_CA_BUNDLE=
UNIFI_CERT_FINGERPRINT=

# ─────────────────────────────────────────────────────────────
# Anthropic API (Phase 7)
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Default model IDs — current as of 2026-04-24
ANTHROPIC_MODEL_DEEP=claude-opus-4-7
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001

# ─────────────────────────────────────────────────────────────
# API server (Phase 10)
# ─────────────────────────────────────────────────────────────
API_SERVER_HOST=127.0.0.1
API_SERVER_PORT=8765
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_BEARER_TOKEN=

# ─────────────────────────────────────────────────────────────
# Supabase (Phase 11)
# ─────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────────────────────
# Cloudflare R2 (Phase 11)
# ─────────────────────────────────────────────────────────────
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=network-engineer-backups

# ─────────────────────────────────────────────────────────────
# Cloud sync behaviour
# ─────────────────────────────────────────────────────────────
CLOUD_SYNC_ENABLED=true
CLOUD_SYNC_MIN_SEVERITY=WARNING
CLOUD_SYNC_TIMEOUT_SEC=5

# ─────────────────────────────────────────────────────────────
# APNs (Phase 12/13)
# ─────────────────────────────────────────────────────────────
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.example.networkEngineer
APNS_USE_SANDBOX=true

# ─────────────────────────────────────────────────────────────
# Cloudflare Tunnel (Phase 14/15 — Mac Studio only)
# ─────────────────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_HOSTNAME=network.example.com
