{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git switch:*)",
      "Bash(git stash:*)",
      "Bash(git add:*)",
      "Bash(git restore --staged:*)",

      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(black:*)",
      "Bash(pip list:*)",
      "Bash(pip show:*)",
      "Bash(pip freeze:*)",

      "Bash(python -m agents.auditor:*)",
      "Bash(python -m agents.reporter:*)",
      "Bash(python -m agents.monitor --once)",
      "Bash(python -m agents.monitor --watch)",
      "Bash(python tools/unifi_client.py --test)",
      "Bash(python tools/permissions.py:*)",

      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(jq:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(uname:*)",
      "Bash(sw_vers:*)",
      "Bash(arch)",
      "Bash(mkdir -p:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",
      "Bash(mv:*)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git checkout:*)",
      "Bash(git restore:*)",
      "Bash(git reset:*)",

      "Bash(pip install:*)",
      "Bash(pip uninstall:*)",
      "Bash(brew:*)",
      "Bash(npm:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",

      "Bash(cloudflared:*)",
      "Bash(launchctl:*)",
      "Bash(uvicorn:*)",
      "Bash(python server/api_server.py:*)",
      "Bash(python -m server:*)",
      "Bash(python -m agents.optimizer:*)",
      "Bash(python -m agents.security_agent:*)",
      "Bash(python -m agents.upgrade_agent:*)",
      "Bash(python tools/rollback.py:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(rm -r /:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git branch -D:*)",
      "Bash(git commit --no-verify:*)",
      "Bash(git push --no-verify:*)",
      "Bash(git config:*)",
      "Bash(sudo:*)",
      "Bash(:(){ :|:& };:)",
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.production)",
      "Edit(./.env)",
      "Edit(./.env.local)",
      "Edit(./.env.production)"
    ]
  },
  "env": {
    "PYTHONDONTWRITEBYTECODE": "1",
    "PYTHONUNBUFFERED": "1"
  }
}
